# Copia este archivo a .env y completa con tus valores reales
# NUNCA hagas: git add .env

# Anthropic API (conseguir en console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-REPLACE_WITH_YOUR_KEY

# Modelo LLM a usar
LLM_MODEL=claude-haiku-4-5-20251001

# Timeout del LLM en segundos (fallback a baseline si supera)
LLM_TIMEOUT_SECONDS=5

# Puerto del servidor
PORT=8000

# Nivel de logging (debug, info, warning, error)
LOG_LEVEL=info
